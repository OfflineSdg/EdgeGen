    {
      "name": "search_direct_flight",
      "description": "Search for direct flights between two cities on a specific date.",
      "input-type": ["airport"],
      "output-type": ["directflight"],
      "input": {
        "origin": {
          "type": "string",
          "description": "The origin city airport in three letters, such as 'JFK'"
        },
        "destination": {
          "type": "string",
          "description": "The destination city airport in three letters, such as 'LAX'"
        },
        "date": {
          "type": "string",
          "description": "The date of the flight in the format 'YYYY-MM-DD', such as '2024-01-01'"
        }
      },
      "output": {
        "type": "array",
        "description": "List of DirectFlight objects",
        "items": {
          "type": "object",
          "properties": {
            "flight_number": {"type": "string"},
            "origin": {"type": "string"},
            "destination": {"type": "string"},
            "status": {"type": "string"},
            "scheduled_departure_time_est": {"type": "string", "description": "HH:MM:SS format"},
            "scheduled_arrival_time_est": {"type": "string", "description": "HH:MM:SS format"},
            "date": {"type": "string", "description": "YYYY-MM-DD format"},
            "available_seats": {
              "type": "object",
              "properties": {
                "business": {"type": "integer"},
                "economy": {"type": "integer"},
                "basic_economy": {"type": "integer"}
              }
            },
            "prices": {
              "type": "object",
              "properties": {
                "business": {"type": "integer"},
                "economy": {"type": "integer"},
                "basic_economy": {"type": "integer"}
              }
            }
          }
        }
      }
    },
    {
      "name": "search_onestop_flight",
      "description": "Search for one-stop flights between two cities on a specific date.",
      "input-type": ["airport"],
      "output-type": ["directflight"],
      "input": {
        "origin": {
          "type": "string",
          "description": "The origin city airport in three letters, such as 'JFK'"
        },
        "destination": {
          "type": "string",
          "description": "The destination city airport in three letters, such as 'LAX'"
        },
        "date": {
          "type": "string",
          "description": "The date of the flight in the format 'YYYY-MM-DD', such as '2024-05-01'"
        }
      },
      "output": {
        "type": "array",
        "description": "List of pairs of DirectFlight objects representing one-stop connections",
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "description": "DirectFlight",
            "properties": {
              "flight_number": {"type": "string"},
              "origin": {"type": "string"},
              "destination": {"type": "string"},
              "status": {"type": "string"},
              "scheduled_departure_time_est": {"type": "string"},
              "scheduled_arrival_time_est": {"type": "string"},
              "date": {"type": "string"},
              "available_seats": {"type": "object"},
              "prices": {"type": "object"}
            }
          },
          "minItems": 2,
          "maxItems": 2
        }
      }
    },
