    {
      "name": "get_user_details",
      "description": "Get the details of a user, including their reservations.",
      "input-type": ["user"],
      "output-type": ["user", "reservation"],
      "input": {
        "user_id": {
          "type": "string",
          "description": "The user ID, such as 'sara_doe_496'"
